# Copy to .env and fill in. .env is git-ignored.
# Pick one environment by setting EVISITOR_ENVIRONMENT.

EVISITOR_ENVIRONMENT=test
EVISITOR_USERNAME=
EVISITOR_PASSWORD=
# API key is required for the test environment, ignored in production.
EVISITOR_API_KEY=

# Optional: enable the live e2e test suite (uses the test environment).
EVISITOR_E2E=0
